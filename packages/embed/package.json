{
  "name": "@memharness/embed",
  "version": "0.1.0",
  "description": "Local, offline-after-download text embeddings for memharness hybrid recall. Lives outside @memharness/core so the storage write path stays model-free (I5).",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/las7/memharness.git",
    "directory": "packages/embed"
  },
  "homepage": "https://github.com/las7/memharness#readme",
  "bugs": {
    "url": "https://github.com/las7/memharness/issues"
  },
  "author": "las7",
  "keywords": ["memory", "agent", "llm", "embeddings", "mcp", "provenance", "bi-temporal"],
  "type": "module",
  "engines": {
    "node": ">=22.13"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
